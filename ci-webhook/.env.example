PORT=3000

# Required — session signing key, generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-strong-random-secret

# Seeded once on first run; skip if user already exists
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Optional — path to SQLite database (defaults to ./reports.db)
DB_PATH=./reports.db
